#!/bin/bash

# Legacy development helper for the batch-overlay-unified.py reference script.
# Output always goes to input_folder/output.

set -e

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BACKEND="$SCRIPT_DIR/batch-overlay-unified.py"

if [ ! -f "$PYTHON_BACKEND" ]; then
    echo "❌ Missing backend script: $PYTHON_BACKEND"
    exit 1
fi

# Show usage
usage() {
    cat << 'EOF'
FPV Batch Overlay - Legacy development helper

USAGE:
  fpv-overlay <input_dir>        Process videos (output → input_dir/output)
  fpv-overlay --interactive      Ask questions
  fpv-overlay --watch <input_dir>  Auto-process new videos

EXAMPLES:
  fpv-overlay ~/my-videos
  fpv-overlay .
  fpv-overlay --interactive
  fpv-overlay --watch ~/videos

FORMATS:
  Input:  .mp4, .mov + .srt (fast) or .osd (beautiful)
  Output: Processed videos in input_dir/output/

EOF
    exit 0
}

# Simple mode: just process all videos
simple_mode() {
    local input_dir="$1"
    local output_dir="$input_dir/output"

    echo "📁 Processing: $input_dir"
    echo "💾 Output:     $output_dir"
    echo ""

    python3 "$PYTHON_BACKEND" "$input_dir" "$output_dir"
}

# Interactive mode: ask questions
interactive_mode() {
    echo ""
    read -p "📁 Video folder? " input_dir
    input_dir="${input_dir:-.}"
    
    local output_dir="$input_dir/output"
    echo "💾 Output will be saved to: $output_dir"
    echo ""

    python3 "$PYTHON_BACKEND" "$input_dir" "$output_dir"
}

# Watch mode: auto-process
watch_mode() {
    local input_dir="$1"
    [ -z "$input_dir" ] && { echo "❌ Watch needs a folder: fpv-overlay --watch <folder>"; exit 1; }

    local output_dir="$input_dir/output"
    mkdir -p "$output_dir"

    echo "⏰ Watching: $input_dir"
    echo "📁 Output:   $output_dir"
    echo "🔄 Auto-processing new videos (Ctrl+C to stop)"
    echo ""

    while true; do
        python3 "$PYTHON_BACKEND" "$input_dir" "$output_dir" 2>/dev/null || true
        sleep 10
    done
}

# Main
case "${1:-}" in
    ""|--help|-h) usage ;;
    --interactive) interactive_mode ;;
    --watch) watch_mode "$2" ;;
    *) simple_mode "$1" ;;
esac
