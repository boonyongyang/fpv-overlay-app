platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '10.15'

      # Fix: app_badge_plus ships PrivacyInfo.xcprivacy which CocoaPods adds to
      # the compile-sources phase on macOS, causing 'no rule to process file of
      # type text.xml' warnings. Exclude those files from compilation.
      if target.name == 'app_badge_plus'
        config.build_settings['EXCLUDED_SOURCE_FILE_NAMES'] = '*.xcprivacy'
      end

    end
  end

  # Fix: suppress Xcode 15 'ignoring duplicate libraries' linker warnings.
  # Several pods independently request the same system libs (-lc++, -lsqlite3,
  # -lz). CocoaPods regenerates xcconfig files during pod install, so we must
  # patch them here (after generation) rather than via config.build_settings.
  %w[debug release profile].each do |config_name|
    xcconfig_path = "Pods/Target Support Files/Pods-Runner/Pods-Runner.#{config_name}.xcconfig"
    next unless File.exist?(xcconfig_path)

    content = File.read(xcconfig_path)
    next if content.include?('-Wl,-no_warn_duplicate_libraries')

    patched = content.sub(
      /^OTHER_LDFLAGS = \$\(inherited\)/,
      'OTHER_LDFLAGS = $(inherited) -Wl,-no_warn_duplicate_libraries'
    )
    File.write(xcconfig_path, patched) if patched != content
  end

  # Patch DockProgress for Swift 6 exhaustiveness error.
  utilities_path = 'Pods/DockProgress/Sources/DockProgress/Utilities.swift'
  if File.exist?(utilities_path)
    puts "Patching #{utilities_path} for Swift 6 support..."
    system("chmod +w #{utilities_path}")
    system("sed -i '' 's/@unknown default/default/g' #{utilities_path}")
  end
end
